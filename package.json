{
  "name": "material",
  "productName": "Courrier-UEX",
  "version": "1.0.0",
  "description": "Data Courrier for UEX Corp.",
  "keywords": [],
  "author": "BlueMystic",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "start": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "desa": "concurrently -k \"npm run dev\" \"npm run start:dev\"",
    "start:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron src/main/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "node build-main.js",
    "build:prod": "npm run build && electron-builder",
    "build:prod:win": "npm run build && electron-builder --win",
    "build:prod:linux": "npm run build && electron-builder --linux",
    "build:prod:all": "npm run build && electron-builder --win --linux",
    "prod": "npm run build && electron ."
  },
  "build": {
    "appId": "com.bluemystic.sccourrieruex",
    "productName": "Courrier-UEX",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "package.json",
      {
        "from": "src/main",
        "to": "dist/main",
        "filter": [
          "*.js"
        ]
      },
      "!dist/renderer/.vite",
      "tessdata/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "tessdata",
        "to": "tessdata",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/Courrier-UEX_Logo_01.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/Courrier-UEX_Logo_01.png",
      "category": "Utility",
      "maintainer": "bluemystic.play@gmail.com",
      "vendor": "BlueMystic",
      "desktop": {
        "Name": "Courrier-UEX",
        "Comment": "Data Courrier for UEX Corp.",
        "GenericName": "Courrier-UEX",
        "Keywords": "material;gestion;inventario;",
        "StartupNotify": "true",
        "Terminal": "false"
      }
    },
    "appImage": {
      "artifactName": "appimage/${productName}-${version}.${ext}"
    },
    "deb": {
      "artifactName": "deb/${productName}_${version}_${arch}.${ext}",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    },
    "rpm": {
      "artifactName": "rpm/${productName}-${version}.${arch}.${ext}",
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-atk",
        "libuuid",
        "libsecret"
      ]
    },
    "tar.gz": {
      "artifactName": "tarball/${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowElevation": true,
      "perMachine": false,
      "runAfterFinish": true,
      "menuCategory": true,
      "shortcutName": "Courrier-UEX",
      "artifactName": "installer/${productName} Setup ${version}.${ext}"
    },
    "portable": {
      "artifactName": "portable/${productName} ${version}.${ext}"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.11",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/themes": "^4.5.4",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "fuse.js": "^7.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  }
}
